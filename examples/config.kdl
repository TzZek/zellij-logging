// Drop-in fragment for ~/.config/zellij/config.kdl.
//
// Either include this file from your main config, or paste these blocks into
// it. Adjust paths and key bindings to taste.

plugins {
    zellij-logging location="file:~/.config/zellij/plugins/zellij_logging.wasm" {
        // Where logs go. Must be reachable through a Zellij WASI mount:
        //   /host  - directory Zellij was launched from
        //   /data  - per-plugin scratch (cleared on plugin unload)
        //   /cache - per-plugin persistent cache
        //   /tmp   - tmpfs
        output_dir         "/host/zellij-logs"

        // Filename template. Placeholders: {session} {tab} {pane_id}
        // {pane_title} {ts} {date} {time}. Subdirectories from `/` in the
        // template are created automatically.
        filename_template  "{date}/{session}-{pane_id}-{ts}.log"

        // Prefix every captured line with an ISO-8601 timestamp. Useful for
        // correlating output with external tools (Burp, responder, SIEM).
        timestamp_lines    true

        // Strip ANSI escape sequences before writing.
        strip_ansi         true

        // If true, start logging the focused pane on plugin load. Off by
        // default to avoid surprising other clients in shared sessions.
        auto_start         false

        // If true, expose the `clear_history` pipe message that wipes the
        // focused pane's scrollback. Requires the ChangeApplicationState
        // permission, which is broader than the clear feature alone needs;
        // off by default for that reason.
        enable_clear_history false

        // If true, also write a sibling `<name>.clean.log` next to each
        // continuous log: no per-line timestamps, ANSI escapes always
        // stripped. Useful as a human-readable companion file you can
        // tail or grep without the timestamps cluttering output. The
        // primary timestamped log is unaffected by this setting.
        clean_log true

        // If true, highlight panes that are currently being continuously
        // logged so you can see at a glance which ones are recording.
        // Auto-requests ChangeApplicationState (also needed by
        // `enable_clear_history`); the permission scope is broader than
        // the highlight alone needs but is cheap to grant once.
        visual_indicator true
    }
}

keybinds {
    shared_except "locked" {
        // Toggle continuous logging for the focused pane.
        // Mnemonic: L = log. Alt+Shift avoids fcitx5's Ctrl+Alt+P
        // (preedit) and most terminal/window-manager defaults.
        bind "Alt Shift l" {
            MessagePlugin "zellij-logging" {
                name "toggle"
            }
        }

        // Save the visible viewport as a one-shot file.
        // Mnemonic: S = snapshot.
        bind "Alt Shift s" {
            MessagePlugin "zellij-logging" {
                name "snapshot"
            }
        }

        // Save the entire scrollback (above + viewport + below) as a
        // one-shot file. Useful at the end of a long shell session.
        // Mnemonic: D = dump.
        bind "Alt Shift d" {
            MessagePlugin "zellij-logging" {
                name "dump_full"
            }
        }

        // Clear the focused pane's scrollback. Only takes effect if
        // `enable_clear_history true` is set in the plugin config above.
        bind "Alt Shift c" {
            MessagePlugin "zellij-logging" {
                name "clear_history"
            }
        }
    }
}
